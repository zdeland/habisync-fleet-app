# Supabase project the HabiSync devices report to.
# Safe to expose to the browser (NEXT_PUBLIC_*): reads are still gated by
# Supabase Auth + RLS using the signed-in user's JWT, never a secret key.
# The publishable key (sb_publishable_...) is the current drop-in
# replacement for the legacy anon JWT key — grab it from
# Project Settings > API Keys > Publishable key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — NEVER prefix this with NEXT_PUBLIC_, never send it to the
# browser. Grabs full admin access bypassing RLS; used only by the /invite
# Server Action (src/app/invite/actions.ts) to pre-create an account so a
# new person can sign in. Project Settings > API Keys > service_role
# secret key.
SUPABASE_SERVICE_ROLE_KEY=
