# Supabase project the HabiSync devices report to.
# Safe to expose to the browser (NEXT_PUBLIC_*): reads are still gated by
# Supabase Auth + RLS using the signed-in user's JWT, never a secret key.
# The publishable key (sb_publishable_...) is the current drop-in
# replacement for the legacy anon JWT key — grab it from
# Project Settings > API Keys > Publishable key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
